{
  "info": {
    "name": "SecureClaims - Admin & Exception Handler (US-016, US-017)",
    "description": "Test collection for US-016 (Admin: List All Users) and US-017 (Global Exception Handler consistency)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "identityUrl", "value": "http://localhost:8081"},
    {"key": "claimsUrl", "value": "http://localhost:8082"},
    {"key": "fraudUrl", "value": "http://localhost:8083"},
    {"key": "notificationUrl", "value": "http://localhost:8084"},
    {"key": "userToken", "value": ""},
    {"key": "adminToken", "value": ""}
  ],
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{identityUrl}}/api/identity/v1/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Admin\",\n  \"lastName\": \"TestUser\",\n  \"email\": \"admin.test@example.com\",\n  \"username\": \"admintest\",\n  \"password\": \"SecureP@ss1\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Register OK', function() { pm.expect([201, 409]).to.include(pm.response.code); });"]}}]
        },
        {
          "name": "Login User (USER role)",
          "request": {
            "method": "POST",
            "url": "{{identityUrl}}/api/identity/v1/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin.test@example.com\",\n  \"password\": \"SecureP@ss1\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Login OK', function() {", "  pm.response.to.have.status(200);", "  pm.collectionVariables.set('userToken', pm.response.json().data.token);", "});"]}}]
        },
        {
          "name": "Login Admin (ADMIN role)",
          "request": {
            "method": "POST",
            "url": "{{identityUrl}}/api/identity/v1/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@secureclaims.com\",\n  \"password\": \"AdminP@ss1\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Admin login OK', function() {", "  pm.response.to.have.status(200);", "  pm.collectionVariables.set('adminToken', pm.response.json().data.token);", "});"]}}]
        }
      ]
    },
    {
      "name": "US-016: Admin List All Users",
      "item": [
        {
          "name": "List All Users - Admin (200)",
          "request": {
            "method": "GET",
            "url": "{{identityUrl}}/api/identity/v1/admin/users?page=0&size=10",
            "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Users listed - 200', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.expect(json.data.content).to.be.an('array');", "  pm.expect(json.data.content.length).to.be.above(0);", "  pm.expect(json.data.content[0]).to.have.property('userId');", "  pm.expect(json.data.content[0]).to.have.property('username');", "  pm.expect(json.data.content[0]).to.have.property('email');", "  pm.expect(json.data.content[0]).to.have.property('roles');", "});"]}}]
        },
        {
          "name": "List Users - USER Token (403)",
          "request": {
            "method": "GET",
            "url": "{{identityUrl}}/api/identity/v1/admin/users",
            "header": [{"key": "Authorization", "value": "Bearer {{userToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Forbidden for USER - 403', function() {", "  pm.response.to.have.status(403);", "});"]}}]
        },
        {
          "name": "List Users - No Token (401)",
          "request": {
            "method": "GET",
            "url": "{{identityUrl}}/api/identity/v1/admin/users",
            "header": []
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Unauthorized - 401', function() {", "  pm.response.to.have.status(401);", "});"]}}]
        }
      ]
    },
    {
      "name": "US-017: Global Exception Handler",
      "item": [
        {
          "name": "Validation Error - Claims (400)",
          "request": {
            "method": "POST",
            "url": "{{claimsUrl}}/api/claims/v1/claims",
            "header": [
              {"key": "Authorization", "value": "Bearer {{userToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Structured 400 response', function() {", "  pm.response.to.have.status(400);", "  var json = pm.response.json();", "  pm.expect(json).to.have.property('timestamp');", "  pm.expect(json).to.have.property('status', 400);", "  pm.expect(json).to.have.property('error');", "  pm.expect(json).to.have.property('message');", "  pm.expect(json).to.have.property('path');", "  pm.expect(json).to.have.property('fieldErrors');", "});"]}}]
        },
        {
          "name": "Not Found - Claims (404)",
          "request": {
            "method": "GET",
            "url": "{{claimsUrl}}/api/claims/v1/claims/00000000-0000-0000-0000-000000000000",
            "header": [{"key": "Authorization", "value": "Bearer {{userToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Structured 404 response', function() {", "  pm.response.to.have.status(404);", "  var json = pm.response.json();", "  pm.expect(json).to.have.property('timestamp');", "  pm.expect(json).to.have.property('status', 404);", "  pm.expect(json).to.have.property('error', 'Not Found');", "  pm.expect(json).to.have.property('message');", "  pm.expect(json).to.have.property('path');", "});"]}}]
        },
        {
          "name": "Forbidden - Claims Admin (403)",
          "request": {
            "method": "GET",
            "url": "{{claimsUrl}}/api/claims/v1/admin/claims",
            "header": [{"key": "Authorization", "value": "Bearer {{userToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Structured 403 response', function() {", "  pm.response.to.have.status(403);", "});"]}}]
        },
        {
          "name": "Validation Error - Identity Register (400)",
          "request": {
            "method": "POST",
            "url": "{{identityUrl}}/api/identity/v1/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"\",\n  \"lastName\": \"\",\n  \"email\": \"not-an-email\",\n  \"username\": \"\",\n  \"password\": \"short\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Structured validation error from Identity', function() {", "  pm.response.to.have.status(400);", "  var json = pm.response.json();", "  pm.expect(json).to.have.property('timestamp');", "  pm.expect(json).to.have.property('status', 400);", "  pm.expect(json).to.have.property('fieldErrors');", "  pm.expect(json.fieldErrors.length).to.be.above(0);", "});"]}}]
        },
        {
          "name": "Not Found - Fraud Admin (404)",
          "request": {
            "method": "GET",
            "url": "{{fraudUrl}}/api/fraud/v1/admin/fraud/00000000-0000-0000-0000-000000000000",
            "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Structured 404 from Fraud service', function() {", "  pm.response.to.have.status(404);", "  var json = pm.response.json();", "  pm.expect(json).to.have.property('timestamp');", "  pm.expect(json).to.have.property('status', 404);", "  pm.expect(json).to.have.property('error');", "  pm.expect(json).to.have.property('message');", "  pm.expect(json).to.have.property('path');", "});"]}}]
        }
      ]
    }
  ]
}
