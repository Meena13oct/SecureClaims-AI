{
  "info": {
    "name": "US-005 & US-006: JWT Authentication & RBAC",
    "_postman_id": "us-005-006-jwt-rbac-tests",
    "description": "Test cases for US-005 (JWT Authentication Filter) and US-006 (Role-Based Access Control & /auth/me endpoint)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://13.207.68.121:8081"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "US-005: Register Test User (Setup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 or 409 (already exists)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"username\": \"janedoe\",\n  \"password\": \"SecureP@ss1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/identity/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "identity", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "US-005: Login to Get Token (Setup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains JWT token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.token).to.be.a('string');",
                  "    pm.expect(jsonData.data.token.length).to.be.greaterThan(50);",
                  "});",
                  "",
                  "var token = pm.response.json().data.token;",
                  "pm.collectionVariables.set('token', token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"SecureP@ss1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/identity/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "identity", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "US-005: JWT Authentication Filter",
      "item": [
        {
          "name": "US-005: Access Secured Endpoint Without Token (Unauthorized - 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 or 403', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});",
                  "",
                  "pm.test('Unauthenticated request is blocked', function () {",
                  "    pm.expect(pm.response.code).to.be.at.least(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/identity/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "identity", "v1", "auth", "me"]
            }
          }
        },
        {
          "name": "US-005: Access Secured Endpoint With Invalid Token (Unauthorized - 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 Unauthorized', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Error message indicates invalid token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('Invalid or expired JWT token');",
                  "});",
                  "",
                  "pm.test('Error response has correct structure', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('status', 401);",
                  "    pm.expect(jsonData).to.have.property('error', 'Unauthorized');",
                  "    pm.expect(jsonData).to.have.property('path', '/api/identity/v1/auth/me');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer invalid.token.string" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/identity/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "identity", "v1", "auth", "me"]
            }
          }
        },
        {
          "name": "US-005: Access Secured Endpoint With Expired Token (Unauthorized - 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 Unauthorized', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Expired token is rejected', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxMjM0NTY3OC0xMjM0LTEyMzQtMTIzNC0xMjM0NTY3ODkwYWIiLCJ1c2VybmFtZSI6InRlc3QiLCJyb2xlcyI6WyJST0xFX1VTRVIiXSwiaWF0IjoxNjAwMDAwMDAwLCJleHAiOjE2MDAwMDAwMDF9.fake_signature" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/identity/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "identity", "v1", "auth", "me"]
            }
          }
        },
        {
          "name": "US-005: Access Public Health Endpoint Without Token (Success - 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Health endpoint returns UP status', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health"]
            }
          }
        },
        {
          "name": "US-005: Access Secured Endpoint With Valid Token (Success - 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('JWT filter passes valid token through', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql(200);",
                  "    pm.expect(jsonData.data).to.not.be.undefined;",
                  "    pm.expect(jsonData.data.userId).to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/identity/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "identity", "v1", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "US-006: Role-Based Access Control & User Profile",
      "item": [
        {
          "name": "US-006: Get Current User Profile (Success - 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has correct envelope', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('timestamp');",
                  "    pm.expect(jsonData).to.have.property('status', 200);",
                  "    pm.expect(jsonData).to.have.property('message', 'Request processed successfully');",
                  "});",
                  "",
                  "pm.test('Profile contains all required fields', function () {",
                  "    var data = pm.response.json().data;",
                  "    pm.expect(data).to.have.property('userId');",
                  "    pm.expect(data).to.have.property('username', 'janedoe');",
                  "    pm.expect(data).to.have.property('email', 'jane.doe@example.com');",
                  "    pm.expect(data).to.have.property('firstName', 'Jane');",
                  "    pm.expect(data).to.have.property('lastName', 'Doe');",
                  "    pm.expect(data).to.have.property('roles');",
                  "});",
                  "",
                  "pm.test('Roles are in ROLE_ format', function () {",
                  "    var data = pm.response.json().data;",
                  "    pm.expect(data.roles).to.be.an('array');",
                  "    pm.expect(data.roles).to.include('ROLE_USER');",
                  "});",
                  "",
                  "pm.test('userId is a valid UUID', function () {",
                  "    var data = pm.response.json().data;",
                  "    var uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;",
                  "    pm.expect(data.userId).to.match(uuidRegex);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/identity/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "identity", "v1", "auth", "me"]
            }
          }
        },
        {
          "name": "US-006: Access Admin Endpoint With USER Token (Forbidden - 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 403 Forbidden', function () {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test('USER role cannot access admin endpoints', function () {",
                  "    pm.expect(pm.response.code).to.eql(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/identity/v1/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "identity", "v1", "admin", "users"]
            }
          }
        },
        {
          "name": "US-006: Access Admin Endpoint Without Token (Unauthorized - 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 or 403', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});",
                  "",
                  "pm.test('Unauthenticated users cannot access admin routes', function () {",
                  "    pm.expect(pm.response.code).to.be.at.least(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/identity/v1/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "identity", "v1", "admin", "users"]
            }
          }
        },
        {
          "name": "US-006: Public Register Endpoint Still Accessible (Success - 201/409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register endpoint is public (no auth required)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 400, 409]);",
                  "});",
                  "",
                  "pm.test('No 401 or 403 on public endpoints', function () {",
                  "    pm.expect(pm.response.code).to.not.eql(401);",
                  "    pm.expect(pm.response.code).to.not.eql(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Public\",\n  \"lastName\": \"Test\",\n  \"email\": \"public.test@example.com\",\n  \"username\": \"publictest\",\n  \"password\": \"SecureP@ss1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/identity/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "identity", "v1", "auth", "register"]
            }
          }
        }
      ]
    }
  ]
}
