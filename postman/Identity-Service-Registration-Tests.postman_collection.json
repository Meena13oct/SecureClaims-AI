{
  "info": {
    "name": "Identity Service - Registration & Login Tests",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Test cases for Identity Service covering US-003 (Registration) and US-004 (Login).\n\nVerifies that the first registered user gets ADMIN role and subsequent users get USER role.\n\nPREREQUISITE: The identity.users and identity.user_roles tables must be empty before running.\n\nEXECUTION ORDER:\n  US-003-TC01 → US-003-TC02 → US-004-TC01 → US-004-TC02\n\nRun the requests strictly in numbered order.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://13.207.68.121:8081",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "regularUserId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "US-003-TC01: Register First User as ADMIN (Success - 201)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// US-003-TC01: Register First User as ADMIN (Success - 201)",
              "",
              "pm.test('US-003-TC01: Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const response = pm.response.json();",
              "",
              "pm.test('US-003-TC01: Response message confirms registration', function () {",
              "    pm.expect(response.message).to.eql('User registered successfully');",
              "});",
              "",
              "pm.test('US-003-TC01: First user is assigned ADMIN role', function () {",
              "    pm.expect(response.data.roles).to.include('ADMIN');",
              "});",
              "",
              "pm.test('US-003-TC01: Response contains a valid userId (UUID)', function () {",
              "    pm.expect(response.data.userId).to.not.be.null;",
              "    pm.expect(response.data.userId).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/);",
              "});",
              "",
              "pm.test('US-003-TC01: Response contains correct username', function () {",
              "    pm.expect(response.data.username).to.eql('adminuser');",
              "});",
              "",
              "pm.test('US-003-TC01: Response contains correct email', function () {",
              "    pm.expect(response.data.email).to.eql('admin@secureclaims.com');",
              "});",
              "",
              "// Store for subsequent tests",
              "if (response.data && response.data.userId) {",
              "    pm.collectionVariables.set('adminUserId', response.data.userId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstName\": \"Admin\",\n    \"lastName\": \"User\",\n    \"email\": \"admin@secureclaims.com\",\n    \"username\": \"adminuser\",\n    \"password\": \"Admin@123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/identity/v1/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "identity", "v1", "auth", "register"]
        }
      }
    },
    {
      "name": "US-003-TC02: Register Second User as USER (Success - 201)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// US-003-TC02: Register Second User as USER (Success - 201)",
              "",
              "pm.test('US-003-TC02: Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const response = pm.response.json();",
              "",
              "pm.test('US-003-TC02: Response message confirms registration', function () {",
              "    pm.expect(response.message).to.eql('User registered successfully');",
              "});",
              "",
              "pm.test('US-003-TC02: Second user is assigned USER role', function () {",
              "    pm.expect(response.data.roles).to.include('USER');",
              "});",
              "",
              "pm.test('US-003-TC02: Second user does NOT have ADMIN role', function () {",
              "    pm.expect(response.data.roles).to.not.include('ADMIN');",
              "});",
              "",
              "pm.test('US-003-TC02: Response contains a valid userId (UUID)', function () {",
              "    pm.expect(response.data.userId).to.not.be.null;",
              "    pm.expect(response.data.userId).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/);",
              "});",
              "",
              "pm.test('US-003-TC02: Response contains correct username', function () {",
              "    pm.expect(response.data.username).to.eql('regularuser');",
              "});",
              "",
              "pm.test('US-003-TC02: Response contains correct email', function () {",
              "    pm.expect(response.data.email).to.eql('user@secureclaims.com');",
              "});",
              "",
              "// Store for subsequent tests",
              "if (response.data && response.data.userId) {",
              "    pm.collectionVariables.set('regularUserId', response.data.userId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstName\": \"Regular\",\n    \"lastName\": \"User\",\n    \"email\": \"user@secureclaims.com\",\n    \"username\": \"regularuser\",\n    \"password\": \"User@1234\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/identity/v1/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "identity", "v1", "auth", "register"]
        }
      }
    },
    {
      "name": "US-004-TC01: Login as Admin (Success - 200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// US-004-TC01: Login as Admin (Success - 200)",
              "",
              "pm.test('US-004-TC01: Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "",
              "pm.test('US-004-TC01: Login returns a JWT token', function () {",
              "    pm.expect(response.data.token).to.not.be.null;",
              "    pm.expect(response.data.token).to.not.be.empty;",
              "});",
              "",
              "// Decode JWT payload and verify ADMIN role",
              "const token = response.data.token;",
              "const payload = JSON.parse(atob(token.split('.')[1]));",
              "",
              "pm.test('US-004-TC01: JWT contains ROLE_ADMIN', function () {",
              "    pm.expect(payload.roles).to.include('ROLE_ADMIN');",
              "});",
              "",
              "pm.test('US-004-TC01: JWT subject matches adminUserId', function () {",
              "    const adminUserId = pm.collectionVariables.get('adminUserId');",
              "    if (adminUserId) {",
              "        pm.expect(payload.sub).to.eql(adminUserId);",
              "    }",
              "});",
              "",
              "// Store admin token for use in protected endpoints",
              "pm.collectionVariables.set('adminToken', token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"admin@secureclaims.com\",\n    \"password\": \"Admin@123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/identity/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "identity", "v1", "auth", "login"]
        }
      }
    },
    {
      "name": "US-004-TC02: Login as Regular User (Success - 200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// US-004-TC02: Login as Regular User (Success - 200)",
              "",
              "pm.test('US-004-TC02: Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "",
              "pm.test('US-004-TC02: Login returns a JWT token', function () {",
              "    pm.expect(response.data.token).to.not.be.null;",
              "    pm.expect(response.data.token).to.not.be.empty;",
              "});",
              "",
              "// Decode JWT payload and verify USER role",
              "const token = response.data.token;",
              "const payload = JSON.parse(atob(token.split('.')[1]));",
              "",
              "pm.test('US-004-TC02: JWT contains ROLE_USER', function () {",
              "    pm.expect(payload.roles).to.include('ROLE_USER');",
              "});",
              "",
              "pm.test('US-004-TC02: JWT does NOT contain ROLE_ADMIN', function () {",
              "    pm.expect(payload.roles).to.not.include('ROLE_ADMIN');",
              "});",
              "",
              "pm.test('US-004-TC02: JWT subject matches regularUserId', function () {",
              "    const regularUserId = pm.collectionVariables.get('regularUserId');",
              "    if (regularUserId) {",
              "        pm.expect(payload.sub).to.eql(regularUserId);",
              "    }",
              "});",
              "",
              "// Store user token for use in user-level endpoints",
              "pm.collectionVariables.set('userToken', token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"user@secureclaims.com\",\n    \"password\": \"User@1234\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/identity/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "identity", "v1", "auth", "login"]
        }
      }
    }
  ]
}
