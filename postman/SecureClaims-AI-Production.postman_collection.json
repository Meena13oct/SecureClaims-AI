      "name": "Identity Service",
      "item": [
        {
          "name": "US-003: Register New User (Success - 201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response contains user data', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.userId).to.not.be.undefined;",
                  "    pm.expect(jsonData.data.username).to.eql('meenaadmin');",
                  "    pm.expect(jsonData.data.roles).to.include('USER');",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.userId) {",
                  "    pm.collectionVariables.set('userId', jsonData.data.userId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Meena\",\n  \"lastName\": \"Admin\",\n  \"email\": \"admin@secureclaims.com\",\n  \"username\": \"meenaadmin\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}:8081/api/identity/v1/auth/register"
          }
        },
        {
          "name": "US-003: Register with Missing Fields (Validation - 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', function() {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Field errors are returned', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.fieldErrors).to.be.an('array');",
                  "    pm.expect(jsonData.fieldErrors.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"\",\n  \"lastName\": \"\",\n  \"email\": \"invalid\",\n  \"username\": \"\",\n  \"password\": \"\"\n}"
            },
            "url": "{{baseUrl}}:8081/api/identity/v1/auth/register"
          }
        },
        {
