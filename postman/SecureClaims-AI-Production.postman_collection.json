      "name": "01. Registration (US-003)",
      "item": [
        {
          "name": "US-003-TC01: Register First User as ADMIN (201)",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('US-003-TC01: Status 201', function() { pm.response.to.have.status(201); });", "var json = pm.response.json();", "pm.test('US-003-TC01: First user gets ADMIN role', function() { pm.expect(json.data.roles).to.include('ADMIN'); });", "pm.test('US-003-TC01: Valid UUID returned', function() { pm.expect(json.data.userId).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/); });", "pm.collectionVariables.set('adminUserId', json.data.userId);"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"firstName\": \"Admin\",\n  \"lastName\": \"User\",\n  \"email\": \"admin@secureclaims.com\",\n  \"username\": \"adminuser\",\n  \"password\": \"Admin@123\"\n}"},
            "url": "{{baseUrl}}:8081/api/identity/v1/auth/register"
          }
        },
        {
          "name": "US-003-TC02: Register Second User as USER (201)",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('US-003-TC02: Status 201', function() { pm.response.to.have.status(201); });", "var json = pm.response.json();", "pm.test('US-003-TC02: Second user gets USER role', function() { pm.expect(json.data.roles).to.include('USER'); });", "pm.test('US-003-TC02: Does NOT have ADMIN', function() { pm.expect(json.data.roles).to.not.include('ADMIN'); });", "pm.collectionVariables.set('userId', json.data.userId);"]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"firstName\": \"Regular\",\n  \"lastName\": \"User\",\n  \"email\": \"user@secureclaims.com\",\n  \"username\": \"regularuser\",\n  \"password\": \"User@1234\"\n}"},
            "url": "{{baseUrl}}:8081/api/identity/v1/auth/register"
          }
        },
        {
          "name": "US-003-TC03: Register with Missing Fields (400)",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('US-003-TC03: Status 400', function() { pm.response.to.have.status(400); });", "pm.test('US-003-TC03: Field errors returned', function() { pm.expect(pm.response.json().fieldErrors).to.be.an('array'); });"]}}],
