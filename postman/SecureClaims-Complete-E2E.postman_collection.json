            },
            "url": "{{baseUrl}}:8081/api/identity/v1/auth/register"
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Admin registered or already exists', function() {", "  pm.expect([201, 409]).to.include(pm.response.code);", "  if (pm.response.code === 201) {", "    pm.collectionVariables.set('adminUserId', pm.response.json().data.userId);", "  }", "});"]}}]
        },
