        },
        {
          "name": "Access /auth/me WITH VALID token (200) ✅",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{userToken}}"}],
            "url": "{{baseUrl}}:8081/api/identity/v1/auth/me"
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Profile returned with valid token - 200', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.expect(json.data.userId).to.not.be.undefined;", "  pm.expect(json.data.username).to.eql('janedoe');", "  pm.expect(json.data.email).to.eql('jane.doe@example.com');", "  pm.expect(json.data.firstName).to.eql('Jane');", "  pm.expect(json.data.lastName).to.eql('Doe');", "  pm.expect(json.data.roles).to.include('ROLE_USER');", "});"]}}]
        },
        {
          "name": "Access /actuator/health WITHOUT token (200 - public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}:8081/actuator/health"
