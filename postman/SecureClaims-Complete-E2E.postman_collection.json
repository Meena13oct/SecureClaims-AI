          "event": [{"listen": "test", "script": {"exec": ["pm.test('User registered or already exists', function() {", "  pm.expect([201, 409]).to.include(pm.response.code);", "  if (pm.response.code === 201) {", "    pm.collectionVariables.set('userId', pm.response.json().data.userId);", "  }", "});"]}}]
        },
        {
