            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"SecureP@ss1\"\n}"
            },
            "url": "{{baseUrl}}:8081/api/identity/v1/auth/login"
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Login successful - 200', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.expect(json.data.token).to.be.a('string');", "  pm.collectionVariables.set('userToken', json.data.token);", "  // Decode JWT to get userId", "  var payload = JSON.parse(atob(json.data.token.split('.')[1]));", "  pm.collectionVariables.set('userId', payload.sub);", "});"]}}]
