{
  "info": {
    "name": "SecureClaims - Claims Service (US-007 to US-010)",
    "description": "Test collection for Claims Service endpoints covering US-007 (Submit Claim), US-008 (View Claims), US-009 (Admin Claims), US-010 (Documents)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8082"},
    {"key": "identityUrl", "value": "http://localhost:8081"},
    {"key": "token", "value": ""},
    {"key": "adminToken", "value": ""},
    {"key": "claimId", "value": ""}
  ],
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{identityUrl}}/api/identity/v1/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Claims\",\n  \"lastName\": \"TestUser\",\n  \"email\": \"claims.test@example.com\",\n  \"username\": \"claimstest\",\n  \"password\": \"SecureP@ss1\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status is 201 or 409', function() {", "  pm.expect([201, 409]).to.include(pm.response.code);", "});"]}}]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "{{identityUrl}}/api/identity/v1/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"claims.test@example.com\",\n  \"password\": \"SecureP@ss1\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Login successful', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.collectionVariables.set('token', json.data.token);", "});"]}}]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "url": "{{identityUrl}}/api/identity/v1/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@secureclaims.com\",\n  \"password\": \"AdminP@ss1\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Admin login successful', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.collectionVariables.set('adminToken', json.data.token);", "});"]}}]
        }
      ]
    },
    {
      "name": "US-007: Submit a Claim",
      "item": [
        {
          "name": "US-007-TC01: Submit Claim (Success - 201)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/claims/v1/claims",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyNumber\": \"POL-2026-00123\",\n  \"claimType\": \"MEDICAL\",\n  \"incidentDate\": \"2026-06-20\",\n  \"description\": \"Hospitalisation due to surgery\",\n  \"claimedAmount\": 75000.00,\n  \"policyAgeMonths\": 3\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Claim submitted - 201 Created', function() {", "  pm.response.to.have.status(201);", "  var json = pm.response.json();", "  pm.expect(json.data.status).to.eql('SUBMITTED');", "  pm.expect(json.data.claimId).to.not.be.undefined;", "  pm.collectionVariables.set('claimId', json.data.claimId);", "});"]}}]
        },
        {
          "name": "US-007-TC02: Submit Claim with Missing Fields (Validation - 400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/claims/v1/claims",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"claimType\": \"MEDICAL\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Validation error - 400', function() {", "  pm.response.to.have.status(400);", "  var json = pm.response.json();", "  pm.expect(json.fieldErrors).to.be.an('array');", "  pm.expect(json.fieldErrors.length).to.be.above(0);", "});"]}}]
        },
        {
          "name": "US-007-TC03: Submit Claim Without Token (Unauthorized - 401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/claims/v1/claims",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyNumber\": \"POL-2026-00123\",\n  \"claimType\": \"MEDICAL\",\n  \"incidentDate\": \"2026-06-20\",\n  \"description\": \"Test\",\n  \"claimedAmount\": 5000.00\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Unauthorized - 401', function() {", "  pm.response.to.have.status(401);", "});"]}}]
        }
      ]
    },
    {
      "name": "US-008: View Claims",
      "item": [
        {
          "name": "US-008-TC01: List My Claims (Success - 200)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/claims/v1/claims?page=0&size=10",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Claims listed - 200', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.expect(json.data.content).to.be.an('array');", "});"]}}]
        },
        {
          "name": "US-008-TC02: Get Claim By ID (Success - 200)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/claims/v1/claims/{{claimId}}",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Claim retrieved - 200', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.expect(json.data.claimId).to.eql(pm.collectionVariables.get('claimId'));", "});"]}}]
        },
        {
          "name": "US-008-TC03: Get Non-Existent Claim (Not Found - 404)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/claims/v1/claims/00000000-0000-0000-0000-000000000000",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Not Found - 404', function() {", "  pm.response.to.have.status(404);", "});"]}}]
        }
      ]
    },
    {
      "name": "US-009: Admin Claims",
      "item": [
        {
          "name": "US-009-TC01: Admin List All Claims (Success - 200)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/claims/v1/admin/claims?page=0&size=10",
            "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Admin claims listed - 200', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.expect(json.data.content).to.be.an('array');", "});"]}}]
        },
        {
          "name": "US-009-TC02: Admin Update Status to UNDER_REVIEW (Success - 200)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/claims/v1/admin/claims/{{claimId}}/status",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"UNDER_REVIEW\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status updated - 200', function() {", "  pm.response.to.have.status(200);", "});"]}}]
        },
        {
          "name": "US-009-TC03: Admin Invalid Status Transition (Bad Request - 400)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/claims/v1/admin/claims/{{claimId}}/status",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CLOSED\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Invalid transition - 400', function() {", "  pm.response.to.have.status(400);", "  var json = pm.response.json();", "  pm.expect(json.message).to.include('Cannot transition');", "});"]}}]
        },
        {
          "name": "US-009-TC04: USER Token on Admin Endpoint (Forbidden - 403)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/claims/v1/admin/claims",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Forbidden - 403', function() {", "  pm.response.to.have.status(403);", "});"]}}]
        }
      ]
    },
    {
      "name": "US-010: Documents",
      "item": [
        {
          "name": "US-010-TC01: List Documents for Claim (Success - 200)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/claims/v1/claims/{{claimId}}/documents",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Documents listed - 200', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.expect(json.data).to.be.an('array');", "});"]}}]
        }
      ]
    }
  ]
}
