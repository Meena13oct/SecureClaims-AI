{
  "info": {
    "name": "US-003: User Registration Tests",
    "_postman_id": "us-003-registration-tests",
    "description": "Comprehensive test cases for US-003 User Registration endpoint (POST /api/identity/v1/auth/register)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://13.207.68.121:8081"
    }
  ],
  "item": [
    {
      "name": "US-003-TC01: Register New User (Success - 201)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has correct structure', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('timestamp');",
              "    pm.expect(jsonData).to.have.property('status', 201);",
              "    pm.expect(jsonData).to.have.property('message', 'User registered successfully');",
              "    pm.expect(jsonData).to.have.property('data');",
              "});",
              "",
              "pm.test('User data contains all expected fields', function () {",
              "    var data = pm.response.json().data;",
              "    pm.expect(data).to.have.property('userId');",
              "    pm.expect(data).to.have.property('username', 'janedoe');",
              "    pm.expect(data).to.have.property('email', 'jane.doe@example.com');",
              "    pm.expect(data).to.have.property('firstName', 'Jane');",
              "    pm.expect(data).to.have.property('lastName', 'Doe');",
              "    pm.expect(data).to.have.property('roles');",
              "});",
              "",
              "pm.test('User has USER role assigned', function () {",
              "    var data = pm.response.json().data;",
              "    pm.expect(data.roles).to.be.an('array');",
              "    pm.expect(data.roles).to.include('USER');",
              "});",
              "",
              "pm.test('Password is not exposed in response', function () {",
              "    var data = pm.response.json().data;",
              "    pm.expect(data).to.not.have.property('password');",
              "    pm.expect(data).to.not.have.property('passwordHash');",
              "});",
              "",
              "pm.test('userId is a valid UUID', function () {",
              "    var data = pm.response.json().data;",
              "    var uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;",
              "    pm.expect(data.userId).to.match(uuidRegex);",
              "});",
              "",
              "// Store userId for dependent tests",
              "if (pm.response.json().data && pm.response.json().data.userId) {",
              "    pm.collectionVariables.set('registeredUserId', pm.response.json().data.userId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"username\": \"janedoe\",\n  \"password\": \"SecureP@ss1\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/identity/v1/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "identity", "v1", "auth", "register"]
        }
      }
    },
    {
      "name": "US-003-TC02: Register Second User (Success - 201)",
      "event": [
