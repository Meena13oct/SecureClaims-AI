              "pm.test('Second user registered with correct details', function () {",
              "    var data = pm.response.json().data;",
              "    pm.expect(data.username).to.eql('johnsmith');",
              "    pm.expect(data.email).to.eql('john.smith@example.com');",
              "    pm.expect(data.firstName).to.eql('John');",
              "    pm.expect(data.lastName).to.eql('Smith');",
              "    pm.expect(data.roles).to.include('USER');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Smith\",\n  \"email\": \"john.smith@example.com\",\n  \"username\": \"johnsmith\",\n  \"password\": \"SecureP@ss2\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/identity/v1/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "identity", "v1", "auth", "register"]
        }
      }
    },
    {
      "name": "US-003-TC03: Register with Missing Fields (Validation - 400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Error response has correct structure', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('timestamp');",
              "    pm.expect(jsonData).to.have.property('status', 400);",
              "    pm.expect(jsonData).to.have.property('error', 'Bad Request');",
              "    pm.expect(jsonData).to.have.property('message', 'One or more fields failed validation');",
              "    pm.expect(jsonData).to.have.property('path');",
              "    pm.expect(jsonData).to.have.property('fieldErrors');",
              "});",
              "",
              "pm.test('Field errors are returned as array', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.fieldErrors).to.be.an('array');",
              "    pm.expect(jsonData.fieldErrors.length).to.be.greaterThan(0);",
              "});",
              "",
              "pm.test('Each field error has field and message', function () {",
              "    var fieldErrors = pm.response.json().fieldErrors;",
              "    fieldErrors.forEach(function(err) {",
              "        pm.expect(err).to.have.property('field');",
              "        pm.expect(err).to.have.property('message');",
              "    });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"\",\n  \"lastName\": \"\",\n  \"email\": \"invalid-email\",\n  \"username\": \"\",\n  \"password\": \"short\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/identity/v1/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "identity", "v1", "auth", "register"]
        }
      }
    },
    {
      "name": "US-003-TC04: Register with Empty Body (Validation - 400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('All required fields reported as errors', function () {",
              "    var fieldErrors = pm.response.json().fieldErrors;",
              "    var fields = fieldErrors.map(function(e) { return e.field; });",
              "    pm.expect(fields).to.include('firstName');",
              "    pm.expect(fields).to.include('lastName');",
              "    pm.expect(fields).to.include('email');",
              "    pm.expect(fields).to.include('username');",
              "    pm.expect(fields).to.include('password');",
              "});"
            ]
          }
        }
