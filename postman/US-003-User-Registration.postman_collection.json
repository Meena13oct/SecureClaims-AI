    {
      "name": "US-003-TC07: Register with Invalid Email Format (Validation - 400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Email validation error is returned', function () {",
              "    var fieldErrors = pm.response.json().fieldErrors;",
              "    var emailError = fieldErrors.find(function(e) { return e.field === 'email'; });",
              "    pm.expect(emailError).to.not.be.undefined;",
              "    pm.expect(emailError.message).to.eql('Must be a valid email address');",
              "});"
            ]
