{
  "info": {
    "name": "SecureClaims - Fraud & Notifications (US-011 to US-015)",
    "description": "Test collection for Fraud Detection (US-011, US-012) and Notification (US-013, US-014) event-driven flows, plus Admin endpoints (US-015)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "claimsUrl", "value": "http://localhost:8082"},
    {"key": "fraudUrl", "value": "http://localhost:8083"},
    {"key": "notificationUrl", "value": "http://localhost:8084"},
    {"key": "identityUrl", "value": "http://localhost:8081"},
    {"key": "userToken", "value": ""},
    {"key": "adminToken", "value": ""},
    {"key": "claimId", "value": ""},
    {"key": "userId", "value": ""}
  ],
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Register Test User",
          "request": {
            "method": "POST",
            "url": "{{identityUrl}}/api/identity/v1/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Fraud\",\n  \"lastName\": \"TestUser\",\n  \"email\": \"fraud.test@example.com\",\n  \"username\": \"fraudtest\",\n  \"password\": \"SecureP@ss1\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Register or already exists', function() {", "  pm.expect([201, 409]).to.include(pm.response.code);", "  if (pm.response.code === 201) {", "    pm.collectionVariables.set('userId', pm.response.json().data.userId);", "  }", "});"]}}]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "{{identityUrl}}/api/identity/v1/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"fraud.test@example.com\",\n  \"password\": \"SecureP@ss1\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Login successful', function() {", "  pm.response.to.have.status(200);", "  pm.collectionVariables.set('userToken', pm.response.json().data.token);", "});"]}}]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "url": "{{identityUrl}}/api/identity/v1/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@secureclaims.com\",\n  \"password\": \"AdminP@ss1\"\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Admin login', function() {", "  pm.response.to.have.status(200);", "  pm.collectionVariables.set('adminToken', pm.response.json().data.token);", "});"]}}]
        }
      ]
    },
    {
      "name": "US-011: Fraud Scoring (High Risk)",
      "item": [
        {
          "name": "US-011-TC01: Submit High-Value Claim for Fraud Scoring (201)",
          "request": {
            "method": "POST",
            "url": "{{claimsUrl}}/api/claims/v1/claims",
            "header": [
              {"key": "Authorization", "value": "Bearer {{userToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyNumber\": \"POL-2026-FRAUD-HIGH\",\n  \"claimType\": \"MEDICAL\",\n  \"incidentDate\": \"2026-06-20\",\n  \"description\": \"High value claim to trigger HIGH risk\",\n  \"claimedAmount\": 60000.00,\n  \"policyAgeMonths\": 3\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Claim submitted', function() {", "  pm.response.to.have.status(201);", "  pm.collectionVariables.set('claimId', pm.response.json().data.claimId);", "});"]}}]
        },
        {
          "name": "US-011-TC02: Verify Fraud Analysis Shows HIGH Risk (200)",
          "request": {
            "method": "GET",
            "url": "{{fraudUrl}}/api/fraud/v1/admin/fraud/{{claimId}}",
            "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Fraud analysis shows HIGH risk', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.expect(json.data.riskLevel).to.eql('HIGH');", "  pm.expect(json.data.riskScore).to.be.above(3);", "});"]}}]
        }
      ]
    },
    {
      "name": "US-012: Auto Status Update",
      "item": [
        {
          "name": "US-012-TC01: Verify Claim Auto-Rejected for HIGH Risk (200)",
          "request": {
            "method": "GET",
            "url": "{{claimsUrl}}/api/claims/v1/claims/{{claimId}}",
            "header": [{"key": "Authorization", "value": "Bearer {{userToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Claim auto-rejected', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.expect(json.data.status).to.eql('REJECTED');", "});"]}}]
        },
        {
          "name": "US-012-TC02: Submit Low-Value Claim for UNDER_REVIEW (201)",
          "request": {
            "method": "POST",
            "url": "{{claimsUrl}}/api/claims/v1/claims",
            "header": [
              {"key": "Authorization", "value": "Bearer {{userToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyNumber\": \"POL-2026-LOW\",\n  \"claimType\": \"PROPERTY\",\n  \"incidentDate\": \"2026-06-25\",\n  \"description\": \"Minor damage - low risk\",\n  \"claimedAmount\": 5000.00,\n  \"policyAgeMonths\": 24\n}"
            }
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Low claim submitted', function() {", "  pm.response.to.have.status(201);", "  pm.collectionVariables.set('lowClaimId', pm.response.json().data.claimId);", "});"]}}]
        }
      ]
    },
    {
      "name": "US-015: Admin Fraud & Notifications",
      "item": [
        {
          "name": "US-015-TC01: Admin Get Fraud Analysis by ClaimId (200)",
          "request": {
            "method": "GET",
            "url": "{{fraudUrl}}/api/fraud/v1/admin/fraud/{{claimId}}",
            "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Fraud analysis retrieved', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.expect(json.data).to.have.property('riskScore');", "  pm.expect(json.data).to.have.property('riskLevel');", "  pm.expect(json.data).to.have.property('analysisNotes');", "});"]}}]
        },
        {
          "name": "US-015-TC02: Admin Get Fraud Analysis Not Found (404)",
          "request": {
            "method": "GET",
            "url": "{{fraudUrl}}/api/fraud/v1/admin/fraud/00000000-0000-0000-0000-000000000000",
            "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Not found - 404', function() {", "  pm.response.to.have.status(404);", "});"]}}]
        },
        {
          "name": "US-015-TC03: Admin Get Notification History (200)",
          "request": {
            "method": "GET",
            "url": "{{notificationUrl}}/api/notifications/v1/admin/notifications/{{userId}}?page=0&size=20",
            "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Notifications retrieved', function() {", "  pm.response.to.have.status(200);", "  var json = pm.response.json();", "  pm.expect(json.data.content).to.be.an('array');", "});"]}}]
        },
        {
          "name": "US-015-TC04: USER Token on Fraud Admin Endpoint (403)",
          "request": {
            "method": "GET",
            "url": "{{fraudUrl}}/api/fraud/v1/admin/fraud/{{claimId}}",
            "header": [{"key": "Authorization", "value": "Bearer {{userToken}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Forbidden - 403', function() {", "  pm.response.to.have.status(403);", "});"]}}]
        }
      ]
    }
  ]
}
